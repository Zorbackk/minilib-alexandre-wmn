//backend/tsconfig.json
{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    // "noEmit": false, = désactivé en production car le npm run build est effectué dans le dockerfile
    "esModuleInterop": true,
    "skipLibCheck": true,
    "checkJs": true,
    "allowJs": true,
    // noEmit : true vérifie les types sans générer de fichiers
    // On garde Node 24 natif pour exécuter -- pas de compilation réelle
  },
  "include": ["src/**/*"]
}
