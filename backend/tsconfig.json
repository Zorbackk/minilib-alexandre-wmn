//backend/tsconfig.json
{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    // noEmit : true vérifie les types sans générer de fichiers
    // On garde Node 24 natif pour exécuter -- pas de compilation réelle
  },
  "include": ["src/**/*"]
}
